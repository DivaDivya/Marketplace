<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">  
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <section class="container mt-5">
        <div class="row justify-content-center" >
            <div class="col-4" >
                <h2>Login</h2>
                <% if (locals.error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <form action="login_user" method="POST" id="loginForm" novalidate>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input name="email" type="text" class="form-control" id="email" placeholder="Enter email" required>
                        <div class="invalid-feedback">Email must contain an '@' sign.</div>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input name="password" type="password" class="form-control" id="password" placeholder="Enter password" required minlength="4">
                        <div class="invalid-feedback">Password must be at least 4 characters.</div>
                    </div>
                    <button type="submit" class="btn btn-primary">Login</button>
                </form>

                <a href="#">Forgot Password</a>
            </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script>
        const form = document.getElementById('loginForm');

        function validateEmail(input) {
            const valid = input.value.includes('@');
            input.setCustomValidity(valid ? '' : "Email must contain an '@' sign.");
            input.classList.toggle('is-invalid', !valid);
            input.classList.toggle('is-valid', valid);
        }

        function validatePassword(input) {
            const valid = input.value.length >= 4;
            input.setCustomValidity(valid ? '' : 'Password must be at least 4 characters.');
            input.classList.toggle('is-invalid', !valid);
            input.classList.toggle('is-valid', valid);
        }

        form.addEventListener('submit', function (e) {
            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');
            validateEmail(emailInput);
            validatePassword(passwordInput);

            if (!form.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
            }
            form.classList.add('was-validated');
        });

        // Real-time validation on blur
        document.getElementById('email').addEventListener('blur', function () {
            validateEmail(this);
        });

        document.getElementById('password').addEventListener('blur', function () {
            validatePassword(this);
        });
    </script>
</body>
</html>
