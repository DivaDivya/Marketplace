<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmed!</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/UC06_style.css">
</head>
<body>
<%- include('partials/header') %>

<div class="main">
    <!-- Step indicator -->
    <div class="checkout-steps">
        <span class="step done">1. Payment Details</span>
        <span class="step-arrow">›</span>
        <span class="step done">2. Review Order</span>
        <span class="step-arrow">›</span>
        <span class="step active">3. Payment Success</span>
    </div>

    <div class="success-body">
        <div class="success-panel">
            <div class="success-icon">✓</div>
            <h1>Payment Successful!</h1>
            <p class="success-subtitle">Your order was placed on <strong><%= orderDate %></strong>. Thank you for shopping with us!</p>

            <table class="order-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% cart.forEach(product => { %>
                    <tr>
                        <td><%= product.listName %></td>
                        <td><%= product.cartQuantity %></td>
                        <td>$<%= parseFloat(product.listPrice).toFixed(2) %></td>
                        <td>$<%= (product.listPrice * product.cartQuantity).toFixed(2) %></td>
                    </tr>
                    <% }) %>
                </tbody>
                <tfoot>
                    <tr class="subtotal-row">
                        <td colspan="3" class="text-end"><strong>Subtotal</strong></td>
                        <td>$<%= subtotal %></td>
                    </tr>
                    <tr>
                        <td colspan="3" class="text-end"><strong>Tax (8.8%)</strong></td>
                        <td>$<%= parseFloat(subtotal * 0.088).toFixed(2) %></td>
                    </tr>
                    <tr class="total-row">
                        <td colspan="3" class="text-end"><strong>Total Charged</strong></td>
                        <td><strong>$<%= parseFloat(subtotal * 1.088).toFixed(2) %></strong></td>
                    </tr>
                </tfoot>
            </table>

            <div class="success-actions">
                <a href="/" class="btn btn-primary">← Back to Home</a>
            </div>
        </div>
    </div>
</div>
</body>
</html>
