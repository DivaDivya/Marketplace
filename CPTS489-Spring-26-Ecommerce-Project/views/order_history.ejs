<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.sellerOrders ? 'Seller Orders' : 'Order History' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="shah384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">  
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/UC07_style.css">
</head>
<body>
    <%- include('partials/header') %>
    <div class="main">
        <div class="history">

            <% if (locals.sellerOrders) { %>
                <!-- Seller Orders View -->
                <p>Seller Orders</p>
                <table>
                    <tr>
                        <th>Date</th>
                        <th>Product Name</th>
                        <th>Customer</th>
                        <th>Quantity</th>
                    </tr>
                    <% if (sellerOrders.length > 0) { %>
                        <% sellerOrders.forEach(order => { %>
                        <tr>
                            <td><%= order.date %></td>
                            <td><%= order.productName %></td>
                            <td><%= order.customerName %></td>
                            <td><%= order.quantity %></td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="4">No orders found</td></tr>
                    <% } %>
                </table>

            <% } else { %>
                <!-- Customer Order History View -->
                <p>Order History</p>
                <table>
                    <tr>
                        <th>Date</th>
                        <th>Item Name</th>
                        <th>Quantity</th>
                        <th>Cost</th>
                    </tr>
                    <% if (orders.length > 0) { %>
                        <% orders.forEach(order => { %>
                        <tr>
                            <td><%= order.orderDate %></td>
                            <td><%= order.listName %></td>
                            <td><%= order.orderQuantity %></td>
                            <td>$<%= order.listPrice * order.orderQuantity %></td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="4">No orders found</td></tr>
                    <% } %>
                </table>
            <% } %>

        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
